# ──────────────────────────────────────────────────────────────────────────
# Browns Studio — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Todas las variables reales viven en Vercel (Settings → Environment Variables).
# Este archivo es solo una referencia de qué keys necesita el proyecto.
#
# Local dev: copia a `.env.local` y rellena los valores.
#   cp .env.example .env.local
#
# Vercel: ya están seteadas en el dashboard del proyecto.
# ──────────────────────────────────────────────────────────────────────────


# ── Admin panel (/admin) ──────────────────────────────────────────────────
# Password que se pide en /admin/login
ADMIN_PASSWORD=

# Secret usado para firmar la cookie de sesión admin (cualquier string largo random)
ADMIN_SECRET=


# ── Firebase (Firestore) — backend de businesses/conversations/leads ──────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANTE: pega la private key completa entre comillas dobles, con \n literales.
# El código hace .replace(/\\n/g, "\n") para convertirlos a saltos de línea.
FIREBASE_PRIVATE_KEY=""


# ── Gemini (IA del bot) ───────────────────────────────────────────────────
GEMINI_API_KEY=
# Opcional — default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash


# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────
# Token de verificación del webhook (lo defines tú, debe coincidir con Meta)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App Secret de la app de Meta — para validar firmas de webhooks entrantes
WHATSAPP_APP_SECRET=

# Credenciales para enviar mensajes salientes
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Teléfono (E.164, ej: +56912345678) al que se notifica cuando el bot
# necesita escalar a un humano. Opcional si cada business define handoff_phone.
HANDOFF_NOTIFICATION_PHONE=


# ── Integraciones externas ────────────────────────────────────────────────
# URL de Calendly por defecto (fallback si un business no tiene la suya).
# Default: https://calendly.com/brownsstudio/consulta
CALENDLY_URL=
