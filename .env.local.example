# ════════════════════════════════════════════════════════════════════════════
# Browns Studio — WhatsApp AI Bot
# Copiá este archivo como .env.local y completá los valores
# NUNCA subas .env.local a git (ya está en .gitignore)
# ════════════════════════════════════════════════════════════════════════════

# ── Meta WhatsApp Business Cloud API ────────────────────────────────────────
# Obtenés estos valores en developers.facebook.com → tu app → WhatsApp
WHATSAPP_PHONE_NUMBER_ID=          # ID numérico del número registrado
WHATSAPP_BUSINESS_ACCOUNT_ID=      # ID numérico de tu WABA
WHATSAPP_ACCESS_TOKEN=             # Token permanente (System Users en Business Manager)
WHATSAPP_APP_SECRET=               # App Secret (en Basic Settings de tu app de Meta)

# Token que vos elegís — Meta lo usa para verificar el webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=browns-studio-webhook-2026

# ── Google Gemini (GRATIS) ────────────────────────────────────────────────────
# Obtené tu key gratis en: https://aistudio.google.com/apikey
# Límite gratis: 1.500 req/día, 1 millón de tokens/día
GEMINI_API_KEY=AIza...

# Modelo (opcional — gemini-2.0-flash es el default, gratis y rápido)
# GEMINI_MODEL=gemini-2.0-flash

# ── Supabase ─────────────────────────────────────────────────────────────────
# supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Segura para uso público (RLS habilitado)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # ⚠️ NUNCA exponer — solo server-side

# ── Bot configuración ────────────────────────────────────────────────────────
# Link de Calendly para agendar llamadas
CALENDLY_URL=https://calendly.com/brownsstudio/consulta

# Tu número personal para recibir notificaciones de leads calientes
# Formato E.164 con +, ej: +56912345678
HANDOFF_NOTIFICATION_PHONE=+56XXXXXXXXX

# ── Sitio ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://brownsstudio.vercel.app

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Contraseña para acceder a /admin
ADMIN_PASSWORD=tu-contraseña-secreta

# Token de sesión — generá uno random: openssl rand -hex 32
ADMIN_SECRET=cambia-esto-por-un-string-aleatorio-largo
